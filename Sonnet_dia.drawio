        <mxCell id="ph_benchmarks" value="&lt;table width=&quot;100%&quot; cellpadding=&quot;4&quot; cellspacing=&quot;0&quot;&gt;&lt;tr&gt;&lt;td colspan=&quot;2&quot; style=&quot;background:#b85450;color:#fff;font-weight:bold;font-size:13px;padding:7px 10px;&quot;&gt;🗄 benchmarks&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f0c0be;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;color:#4d0a08;&quot;&gt;&lt;b&gt;🔑 PK&lt;/b&gt; id&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED AUTO_INCREMENT&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;&lt;i&gt;🔗 FK&lt;/i&gt; component_id&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED (→ components_gpu.id)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fdf0f0;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;&lt;i&gt;🔗 FK&lt;/i&gt; game_id&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED → games.id&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;resolution&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;VARCHAR(20) (напр. 1920x1080)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fdf0f0;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;settings&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;ENUM('low','medium','high','ultra')&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;avg_fps&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fdf0f0;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;min_fps&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;max_fps&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;spacingLeft=0;spacingTop=0;overflow=fill;rotatable=0;whiteSpace=wrap;rounded=1;arcSize=3;strokeWidth=2;" vertex="1" parent="grp_games">
