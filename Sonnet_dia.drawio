      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="lg_user" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=14;strokeWidth=2;fillColor=#dae8fc;strokeColor=#6c8ebf" value="&lt;div&gt;&lt;b&gt;USER&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;User ID&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Username&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Email&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Role&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Status&lt;/b&gt;&lt;/div&gt;" vertex="1">
