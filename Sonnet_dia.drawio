        </mxCell>
        <mxCell id="lg_build_component" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=14;strokeWidth=2;fillColor=#fff2cc;strokeColor=#d6b656" value="&lt;div&gt;&lt;b&gt;ASSEMBLY COMPONENTS&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Record ID&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Assembly&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Component&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Quantity&lt;/b&gt;&lt;/div&gt;" vertex="1">
