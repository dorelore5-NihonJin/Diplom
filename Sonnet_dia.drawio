;background:#edf4fc;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;device&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;VARCHAR(50)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;created_at&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;DATETIME NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#edf4fc;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;last_seen&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;DATETIME NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;spacingLeft=0;spacingTop=0;overflow=fill;rotatable=0;whiteSpace=wrap;rounded=1;arcSize=3;strokeWidth=2;" vertex="1" parent="grp_users">
