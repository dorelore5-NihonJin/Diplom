  <diagram id="physical-db-hyperpc" name="Физическая схема БД">
    <mxGraphModel dx="3200" dy="2000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════════════════
             GROUP LABELS (background swim-lanes per domain)
        ════════════════════════════════════════════════════════════════ -->

        <!-- GROUP: Пользователи -->
        <mxCell id="grp_users" value="👤  Пользователи &amp; Сессии" style="swimlane;startSize=34;fillColor=#e8f4fd;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;fontColor=#1a5276;strokeWidth=2;rounded=1;arcSize=4;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="760" height="820" as="geometry" />
        </mxCell>

        <!-- GROUP: Компоненты -->
        <mxCell id="grp_components" value="🖥  Категории &amp; Компоненты" style="swimlane;startSize=34;fillColor=#eafaf1;strokeColor=#82b366;fontStyle=1;fontSize=13;fontColor=#1e8449;strokeWidth=2;rounded=1;arcSize=4;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="40" width="1080" height="820" as="geometry" />
        </mxCell>

        <!-- GROUP: Сборки -->
        <mxCell id="grp_builds" value="⚙  Сборки ПК" style="swimlane;startSize=34;fillColor=#fefde7;strokeColor=#d6b656;fontStyle=1;fontSize=13;fontColor=#7d6608;strokeWidth=2;rounded=1;arcSize=4;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="900" width="760" height="640" as="geometry" />
        </mxCell>

        <!-- GROUP: Заказы -->
        <mxCell id="grp_orders" value="🛒  Заказы &amp; Уведомления" style="swimlane;startSize=34;fillColor=#fff5e6;strokeColor=#d79b00;fontStyle=1;fontSize=13;fontColor=#784212;strokeWidth=2;rounded=1;arcSize=4;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="900" width="1080" height="640" as="geometry" />
        </mxCell>

        <!-- GROUP: Отзывы + Тикеты -->
        <mxCell id="grp_support" value="💬  Отзывы &amp; Поддержка" style="swimlane;startSize=34;fillColor=#f5eef8;strokeColor=#9673a6;fontStyle=1;fontSize=13;fontColor=#512e5f;strokeWidth=2;rounded=1;arcSize=4;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="1580" width="760" height="600" as="geometry" />
        </mxCell>

        <!-- GROUP: Игры + Бенчмарки -->
        <mxCell id="grp_games" value="🎮  Игры &amp; Бенчмарки" style="swimlane;startSize=34;fillColor=#fdedec;strokeColor=#b85450;fontStyle=1;fontSize=13;fontColor=#78281f;strokeWidth=2;rounded=1;arcSize=4;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="1580" width="1080" height="600" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════════
             TABLE: users  (внутри grp_users)
        ════════════════════════════════════════════════════════════════ -->
        <mxCell id="ph_users" value="&lt;table width=&quot;100%&quot; cellpadding=&quot;4&quot; cellspacing=&quot;0&quot;&gt;&lt;tr&gt;&lt;td colspan=&quot;2&quot; style=&quot;background:#6c8ebf;color:#fff;font-weight:bold;font-size:13px;padding:7px 10px;border-radius:4px 4px 0 0;&quot;&gt;🗄 users&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#c8dff5;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;color:#1a3a5c;&quot;&gt;&lt;b&gt;🔑 PK&lt;/b&gt; id&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED AUTO_INCREMENT&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;username&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;VARCHAR(100) NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#edf4fc;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;email&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;VARCHAR(255) UNIQUE NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;password&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;VARCHAR(255) NOT NULL&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#edf4fc;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;role&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;ENUM('user','admin','moderator')&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;status&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;ENUM('active','blocked','deleted')&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#edf4fc;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;&lt;i&gt;🔗 FK&lt;/i&gt; blocked_by&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;INT UNSIGNED NULL → users.id&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;avatar&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;VARCHAR(255)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#edf4fc;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;bio&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;TEXT&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;location&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;VARCHAR(255)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#edf4fc;&quot;&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;created_at&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;TIMESTAMP DEFAULT NOW()&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:3px 8px;font-size:11px;&quot;&gt;updated_at&lt;/td&gt;&lt;td style=&quot;font-size:11px;color:#555;&quot;&gt;TIMESTAMP ON UPDATE NOW()&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;spacingLeft=0;spacingTop=0;overflow=fill;rotatable=0;whiteSpace=wrap;rounded=1;arcSize=3;strokeWidth=2;" vertex="1" parent="grp_users">
          <mxGeometry x="20" y="50" width="380" height="310" as="geometry" />
        </mxCell>

        <!-- TABLE: password_resets -->
